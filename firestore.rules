rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'enomine.hao@gmail.com';
    }

    // Documento del usuario
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      // Subcolecciones (customers, sales, etc.)
      match /{subCollection}/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /approved_users/{approvedUserId} {
      allow read, write: if isAdmin();
      allow get: if request.auth != null && request.auth.uid == approvedUserId;
    }
  }
}